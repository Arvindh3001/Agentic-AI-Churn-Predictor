# ============================================================
# Churn Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql://churn_user:churn_pass@localhost:5432/churn_db
REDIS_URL=redis://localhost:6379/0

# ---- ChromaDB (Vector Store) ----
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=churn-prediction
MLFLOW_MODEL_NAME=churn-ensemble

# ---- LLM APIs (Phase 3) ----
OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ---- LangSmith (Phase 3 — Agent Observability) ----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=churn-platform-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- JWT (Phase 6 — Authentication) ----
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Slack (Phase 5 — HITL Notifications) ----
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_CHANNEL=#churn-alerts

# ---- App Config ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
WORKERS=4

# ---- Feature Store ----
FEAST_REPO_PATH=./data/feature_store

# ---- Data Paths ----
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
SYNTHETIC_DATA_PATH=./data/synthetic

# ---- Model Config ----
CHURN_THRESHOLD=0.5
CONFIDENCE_INTERVAL_ALPHA=0.1
