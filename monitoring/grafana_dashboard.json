{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Churn Intelligence Platform",
  "uid": "churn-platform-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["churn", "ml", "agents"],
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(http_requests_total[1m])) * 60",
          "legendFormat": "Requests/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "API Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Churn Predictions per Minute",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(churn_predictions_total[1m])) * 60",
          "legendFormat": "Predictions/min"
        }
      ]
    },
    {
      "id": 4,
      "title": "HITL Pending Approvals",
      "type": "stat",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hitl_pending_count",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Model AUC-ROC",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 6, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "model_auc_roc_current",
          "legendFormat": "AUC-ROC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.88 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Celery Queue Depth",
      "type": "stat",
      "gridPos": { "x": 8, "y": 6, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(celery_tasks_pending)",
          "legendFormat": "Queued tasks"
        }
      ]
    },
    {
      "id": 7,
      "title": "Agent Pipeline Duration (p95)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 6, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, rate(agent_pipeline_duration_seconds_bucket[10m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Feature Drift PSI",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "feature_drift_psi",
          "legendFormat": "{{feature_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 9,
      "title": "Churn Probability Distribution",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(churn_probability_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(http_requests_total{status_code=~'5..'}[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "5xx error rate %"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(http_requests_total{status_code=~'4..'}[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "4xx error rate %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 11,
      "title": "Predictions by Risk Tier",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (risk_tier)(churn_predictions_total)",
          "legendFormat": "{{risk_tier}}"
        }
      ]
    }
  ]
}
